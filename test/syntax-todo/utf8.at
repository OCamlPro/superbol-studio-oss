# -*- coding: utf-8 -*-

# Tests dedicated to checking proper handling of UTF-8 characters by
# CLI tools


AT_SETUP([UTF8 locations])
AT_DATA([prog.cob], [
     1 IDENTIFICATION DIVISION.
     2 PROGRAM-ID. prog.
     3 DATA DIVISION.
     4 WORKING-STORAGE SECTION.
     5 01 W.
     6*                                    ,- missing dot here
     7   02 V PICTURE X(20) VALUE "αβ d εφ"
     8 PROCEDURE DIVISION.
     9    DISPLAY V
    10    STOP RUN.
])

AT_CHECK([$SUPERBOL check --recovery=true prog.cob], [0], [Checking `prog.cob'
],
[SuperBOL, by OCamlPro. https://get-superbol.com. Affero GPL version.
prog.cob:8.43:
   5        4 WORKING-STORAGE SECTION.
   6        5 01 W.
   7        6*                                    ,- missing dot here
   8 >      7   02 V PICTURE X(20) VALUE "αβ d εφ"
----                                              ^
   9        8 PROCEDURE DIVISION.
  10        9    DISPLAY V
>> Hint: Missing .

prog.cob:9.7-9.16:
   6        5 01 W.
   7        6*                                    ,- missing dot here
   8        7   02 V PICTURE X(20) VALUE "αβ d εφ"
   9 >      8 PROCEDURE DIVISION.
----          ^^^^^^^^^
  10        9    DISPLAY V
  11       10    STOP RUN.
>> Warning: Invalid syntax

])

AT_CLEANUP

